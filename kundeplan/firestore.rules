rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Bootstrap super-admin email. This account always has admin rights so
    // it can seed and manage the admins list document. Exempt from the
    // email-verification check so the project owner can bootstrap access.
    function superAdminEmail() {
      return 'ernst.magne.carlsen@atea.no';
    }

    // Only @atea.no accounts may use the app.
    function allowedEmailDomain() {
      return 'atea.no';
    }

    function callerEmail() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function emailDomain(email) {
      return email.split('@').size() == 2 ? email.split('@')[1] : '';
    }

    // Trusted = signed in, with a verified email on the allowed domain.
    // The super-admin is always trusted so they can bootstrap the admins doc
    // even before verifying their email.
    function isTrustedUser() {
      return request.auth != null
        && callerEmail() != ''
        && (
          callerEmail() == superAdminEmail()
          || (
            request.auth.token.email_verified == true
            && emailDomain(callerEmail()) == allowedEmailDomain()
          )
        );
    }

    function adminsDoc() {
      return get(/databases/$(database)/documents/kundeplanAdmins/list);
    }

    function adminsList() {
      return exists(/databases/$(database)/documents/kundeplanAdmins/list)
        ? adminsDoc().data.emails
        : [];
    }

    function editorsList() {
      return exists(/databases/$(database)/documents/kundeplanEditors/list)
        ? get(/databases/$(database)/documents/kundeplanEditors/list).data.emails
        : [];
    }

    function isAdminUser() {
      return isTrustedUser()
        && (
          callerEmail() == superAdminEmail()
          || callerEmail() in adminsList()
        );
    }

    // Editor = admin OR explicitly listed editor. Editors can write the
    // runbook but cannot edit the blueprint or manage users.
    function isEditorUser() {
      return isTrustedUser()
        && (
          isAdminUser()
          || callerEmail() in editorsList()
        );
    }

    // Shared cloud sync document. All trusted users READ it so everyone sees
    // the same data; only admin users may WRITE.
    match /kundeplanStates/{userKey} {
      allow read: if isTrustedUser();
      allow write: if isAdminUser();
    }

    // Admin list document. Any trusted user may read it (so the UI can tell
    // whether they are an admin); only admin users may write it.
    match /kundeplanAdmins/{docId} {
      allow read: if isTrustedUser();
      allow write: if isAdminUser();
    }

    // Editor list document. Trusted users read; admins write.
    match /kundeplanEditors/{docId} {
      allow read: if isTrustedUser();
      allow write: if isAdminUser();
    }

    // Full user registry with roles, display name, audit fields. Trusted
    // users read (so the UI can show roles); admins write.
    match /kundeplanUsers/{docId} {
      allow read: if isTrustedUser();
      allow write: if isAdminUser();
    }

    // Shared runbook config (per-step status, notes, assignee, due date).
    // Trusted users read; admins AND editors may write.
    match /kundeplanRunbook/{docId} {
      allow read: if isTrustedUser();
      allow write: if isEditorUser();
    }

    // Template repository: named snapshots of blueprint + runbook config.
    // All trusted users may read (so viewers can browse + export); only
    // admins may create, update, or delete templates.
    match /kundeplanTemplates/{docId} {
      allow read: if isTrustedUser();
      allow write: if isAdminUser();
    }

    // Phase 4 — multi-plan registry. List of named plans the workspace
    // knows about. The default plan is implicit and is not stored here.
    // Trusted users read (so they can pick a plan); only admins may write.
    match /kundeplanPlans/{docId} {
      allow read: if isTrustedUser();
      allow write: if isAdminUser();
    }

    // Phase 3 — append-only audit log. Each document is a single event.
    // Trusted users may read so the Activity panel can render history.
    // Editors (and admins, since admins satisfy isEditorUser) may CREATE
    // new events, but only with their own email as the actor and the
    // expected schema version. Nobody may modify or delete past events.
    match /kundeplanAudit/{eventId} {
      allow read: if isTrustedUser();
      allow create: if isEditorUser()
        && request.resource.data.schemaVersion == 1
        && request.resource.data.actor.email == callerEmail()
        && request.resource.data.type is string
        && request.resource.data.type.size() > 0
        && request.resource.data.type.size() <= 64;
      allow update, delete: if false;
    }

    // Phase 5 — per-entity comments (blueprint parts + runbook steps).
    // Trusted users read so threads are visible. Editors/admins can CREATE
    // a comment, but only with their own email as the author and an
    // allowed entityType. Authors can UPDATE their own comment body (the
    // immutable fields are pinned). Admins or the comment author can DELETE.
    match /kundeplanComments/{commentId} {
      allow read: if isTrustedUser();

      allow create: if isEditorUser()
        && request.resource.data.schemaVersion == 1
        && request.resource.data.author.email == callerEmail()
        && request.resource.data.entityType in ['part', 'runbookStep']
        && request.resource.data.entityId is string
        && request.resource.data.entityId.size() > 0
        && request.resource.data.planId is string
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 4000;

      allow update: if isEditorUser()
        && resource.data.author.email == callerEmail()
        && request.resource.data.author.email == resource.data.author.email
        && request.resource.data.schemaVersion == resource.data.schemaVersion
        && request.resource.data.entityType == resource.data.entityType
        && request.resource.data.entityId == resource.data.entityId
        && request.resource.data.planId == resource.data.planId
        && request.resource.data.entityKey == resource.data.entityKey
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 4000;

      allow delete: if isAdminUser()
        || (isEditorUser() && resource.data.author.email == callerEmail());
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

